test_settings={
    'theme': 'light',
    'key2': 'value2',
    'key3': 'Value3'
}

def add_setting(test_setting,setting_pair):
    key,value=setting_pair
    key=key.lower()
    value=value.lower()
    
    if  key in test_setting:
        return f"Setting '{key}' already exists! Cannot add a new setting with this name."
    else:
        test_setting[key]=value        
        return f"Setting '{key}' added with value '{value}' successfully!"

def update_setting(test_setting,setting_pair):
    key,value=setting_pair
    key=key.lower()
    value=value.lower()

    if key not in test_setting:
        return f"Setting '{key}' does not exist! Cannot update a non-existing setting."

    test_setting[key]=value
    return f"Setting '{key}' updated to '{value}' successfully!"

def delete_setting(test_setting,setting_pair):
    key=setting_pair
    key=key.lower()
    if key in test_setting:
        del test_setting[key]
        return f"Setting '{key}' deleted successfully!"
    else:
        return "Setting not found!"

def view_settings(test_setting):
    if not test_setting:
        return "No settings available."
    
    result="Current User Settings:\n"
    for key,value in test_setting.items():
        result += f"{key.capitalize()}: {value}\n"
    return result

